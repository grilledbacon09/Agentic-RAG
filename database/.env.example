DB_HOST=localhost
DB_NAME=med_db
DB_USER=postgres
DB_PASSWORD=postgres111

MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=minio111

CHROMA_HOST=localhost
CHROMA_PORT=8000

# 공공데이터포털 (https://www.data.go.kr) 발급 키
# e약은요 - DrbEasyDrugInfoService (필수)
API_KEY_1=your_encoding_or_decoding_service_key_here
# DUR 병용금기 - DURPrdlstInfoService03 (선택, 없으면 taboo 스킵)
API_KEY_2=your_dur_service_key_here
# api_collector.py 호환 alias
PUBLIC_DATA_API_KEY=your_encoding_or_decoding_service_key_here

# 임베딩: simple(저메모리, 권장) | onnx | sentence-transformers
EMBEDDING_BACKEND=simple
EMBEDDING_DIM=384

# VectorDB 적재 (메모리 안전 기본값)
VECTOR_BATCH_SIZE=32
VECTOR_MAX_MAPPING_CHUNKS=50000

# Silver: 일반의약품만 적재 (OTC 추천 서비스용)
SILVER_OTC_ONLY=true

# API 수집
API_PAGE_SIZE=100
API_PAGE_DELAY=0.2
INGEST_TABOO=true
